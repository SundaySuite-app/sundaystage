{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SundayStage Output",
  "version": "0.2.1",
  "identifier": "no.sundaystage.output",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "output-child",
          "description": "The crash-isolated output process window: receive ss://render and ss://heartbeat events and call the two late-join commands.",
          "windows": ["output-*"],
          "permissions": ["core:default"]
        }
      ]
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
